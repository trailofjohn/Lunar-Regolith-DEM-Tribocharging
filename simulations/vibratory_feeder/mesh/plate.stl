solid OpenSCAD_Model
  facet normal -0 0 1
    outer loop
      vertex -100 100 0
      vertex 100 -100 0
      vertex 100 100 0
    endloop
  endfacet
  facet normal 0 0 1
    outer loop
      vertex 100 -100 0
      vertex -100 100 0
      vertex -100 -100 0
    endloop
  endfacet
  facet normal 0 0 -1
    outer loop
      vertex -100 -100 -1
      vertex 100 100 -1
      vertex 100 -100 -1
    endloop
  endfacet
  facet normal -0 0 -1
    outer loop
      vertex 100 100 -1
      vertex -100 -100 -1
      vertex -100 100 -1
    endloop
  endfacet
  facet normal 0 -1 0
    outer loop
      vertex -100 -100 -1
      vertex 100 -100 0
      vertex -100 -100 0
    endloop
  endfacet
  facet normal 0 -1 -0
    outer loop
      vertex 100 -100 0
      vertex -100 -100 -1
      vertex 100 -100 -1
    endloop
  endfacet
  facet normal 1 -0 0
    outer loop
      vertex 100 -100 0
      vertex 100 100 -1
      vertex 100 100 0
    endloop
  endfacet
  facet normal 1 0 0
    outer loop
      vertex 100 100 -1
      vertex 100 -100 0
      vertex 100 -100 -1
    endloop
  endfacet
  facet normal 0 1 -0
    outer loop
      vertex 100 100 -1
      vertex -100 100 0
      vertex 100 100 0
    endloop
  endfacet
  facet normal 0 1 0
    outer loop
      vertex -100 100 0
      vertex 100 100 -1
      vertex -100 100 -1
    endloop
  endfacet
  facet normal -1 0 0
    outer loop
      vertex -100 -100 -1
      vertex -100 100 0
      vertex -100 100 -1
    endloop
  endfacet
  facet normal -1 -0 0
    outer loop
      vertex -100 100 0
      vertex -100 -100 -1
      vertex -100 -100 0
    endloop
  endfacet
endsolid OpenSCAD_Model
